generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String     @id @default(uuid())
  name          String
  email         String     @unique
  password_hash String
  role          Role       @default(STAFF)
  created_at    DateTime   @default(now())
  is_approved   Boolean    @default(false)
  audit_logs    AuditLog[]
  orders        Order[]    @relation("CreatedOrders")

  @@map("users")
}

model Product {
  id                    String      @id @default(uuid())
  name                  String
  cost_price            Decimal
  default_selling_price Decimal?
  created_at            DateTime    @default(now())
  updated_at            DateTime    @updatedAt
  order_items           OrderItem[]

  @@map("products")
}

model Order {
  id                  String      @id
  customer_name       String
  mobile_number       String
  address             String
  order_date          DateTime    @default(now())
  status              OrderStatus @default(PENDING)
  shipping_cost       Decimal
  total_selling_price Decimal
  total_cost_price    Decimal
  net_profit          Decimal
  created_by_id       String
  created_at          DateTime    @default(now())
  updated_at          DateTime    @updatedAt
  status_updated_at   DateTime?   @default(now())
  notes               String?
  shipping_method     String
  items               OrderItem[]
  created_by          User        @relation("CreatedOrders", fields: [created_by_id], references: [id])

  @@map("orders")
}

model OrderItem {
  id               String   @id @default(uuid())
  order_id         String
  product_id       String?
  product_name     String
  quantity         Int
  cost_price       Decimal
  selling_price    Decimal
  total_item_value Decimal
  order            Order    @relation(fields: [order_id], references: [id])
  product          Product? @relation(fields: [product_id], references: [id])

  @@map("order_items")
}

model AuditLog {
  id             String   @id @default(uuid())
  user_id        String
  action         String
  target_id      String
  previous_value Json?
  new_value      Json?
  timestamp      DateTime @default(now())
  user           User     @relation(fields: [user_id], references: [id])

  @@map("audit_logs")
}

enum Role {
  ADMIN
  STAFF
}

enum OrderStatus {
  PENDING
  DISPATCHED
  DELIVERED
  RETURNED
  CANCELLED
  DRAFT
}
